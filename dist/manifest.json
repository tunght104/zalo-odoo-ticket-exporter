{
  "manifest_version": 3,
  "name": "Zalo Message Exporter",
  "version": "1.0.0",
  "description": "Chọn và xuất tin nhắn Zalo theo định dạng hội thoại",
  "action": {
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://chat.zalo.me/*"],
      "js": ["zalo-content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "scripting",
    "tabs",
    "activeTab",
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://chat.zalo.me/*"
  ]
}
